{
  "name": "feishu-bot-chat",
  "version": "0.3.0",
  "description": "OpenClaw plugin for bot-to-bot @ communication in Feishu/Lark group chats | 飞书群聊机器人间 A2A 协作通信插件，支持自动发现、任务分解、链式调用",
  "main": "index.js",
  "author": {
    "name": "langyuhero"
  },
  "contributors": [
    {
      "name": "Leochens",
      "url": "https://github.com/Leochens"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/langyuhero/openclaw-feishu-a2a.git"
  },
  "keywords": [
    "openclaw",
    "feishu",
    "lark",
    "飞书",
    "bot",
    "a2a",
    "agent-to-agent",
    "plugin",
    "collaboration",
    "群聊",
    "机器人协作",
    "multi-agent"
  ],
  "scripts": {
    "build": "node scripts/build.js"
  },
  "files": [
    "index.js",
    "lib/",
    "openclaw.plugin.json",
    "skills/",
    "README.md",
    "HOOK.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "hooks": [
      "before_prompt_build",
      "message_sending",
      "inbound_claim"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.15",
      "pluginSdkVersion": "2026.4.15"
    }
  }
}
